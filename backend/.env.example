# Required for real pipeline (Section D+). If unset, API uses mock mode (placeholder output) for local verification.
OPENAI_API_KEY=

# Optional: vector store ID for knowledge retrieval during real generation. When set, file_search is attached to requests.
# OPENAI_VECTOR_STORE_ID=vs_xxxxxxxx

# Optional: set to 1 to force mock mode even when OPENAI_API_KEY is set (e.g. local testing).
# USE_MOCK_LLM=1
