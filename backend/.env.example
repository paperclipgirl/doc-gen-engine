# Required for real pipeline (Section D+). If unset, API uses mock mode (placeholder output) for local verification.
OPENAI_API_KEY=

# Optional: vector store ID for knowledge retrieval (quick and production). When set, file_search is attached.
# OPENAI_VECTOR_STORE_ID=vs_xxxxxxxx

# Optional: model per mode (defaults: gpt-4.1-mini for quick, gpt-4.1 for production).
# OPENAI_MODEL_QUICK=gpt-4.1-mini
# OPENAI_MODEL_PRODUCTION=gpt-4.1

# Optional: set to 1 to force mock mode even when OPENAI_API_KEY is set (e.g. local testing).
# USE_MOCK_LLM=1
